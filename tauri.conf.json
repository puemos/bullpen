{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bullpen",
  "version": "0.3.4",
  "identifier": "dev.puemos.bullpen",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm dev --host 127.0.0.1",
      "cwd": "frontend"
    },
    "beforeBuildCommand": {
      "script": "pnpm build",
      "cwd": "frontend"
    },
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bullpen",
        "width": 1220,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
